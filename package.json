{
  "name": "deepfield",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "CLOUDFLARE_ENV=production vite build",
    "build:development": "CLOUDFLARE_ENV=development vite build",
    "build:worker": "CLOUDFLARE_ENV=production vite build",
    "db:generate": "corepack pnpm --filter @deepfield/db db:generate",
    "db:migrate": "corepack pnpm --filter @deepfield/db db:migrate",
    "db:push": "corepack pnpm --filter @deepfield/db db:push",
    "db:studio": "corepack pnpm --filter @deepfield/db db:studio",
    "deploy": "pnpm run docs:sync && CLOUDFLARE_ENV=production vite build && pnpm run docs:r2:create && pnpm run docs:r2:upload && wrangler deploy",
    "dev": "sh -c 'trap \"kill 0\" EXIT INT TERM; pnpm run docs:watch & pnpm run dev:web'",
    "dev:web": "react-router dev",
    "dev:worker": "CLOUDFLARE_ENV=development vite dev",
    "docs:sync": "node --import tsx scripts/generate.ts",
    "docs:r2:create": "wrangler r2 bucket create deepfield-doc-assets || true",
    "docs:r2:upload": "bash -lc 'set -euo pipefail; for dir in public/kr public/images; do if [ ! -d \"$dir\" ]; then echo \"[docs:r2] skip missing $dir\"; continue; fi; echo \"[docs:r2] upload $dir\"; find \"$dir\" -type f ! -name .DS_Store ! -name .assetsignore -print0 | while IFS= read -r -d \"\" file; do key=\"${file#public/}\"; wrangler r2 object put \"deepfield-doc-assets/$key\" --file \"$file\" --remote --force; done; done'",
    "docs:watch": "node --import tsx scripts/watch-docs.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@react-router/dev": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@takumi-rs/image-response": "^1.0.15",
    "fumadocs-core": "^16.8.1",
    "fumadocs-mdx": "^14.3.1",
    "fumadocs-obsidian": "^0.1.0",
    "fumadocs-ui": "^16.8.1",
    "gasp": "^0.0.2",
    "gsap": "^3.15.0",
    "isbot": "^5",
    "katex": "^0.16.45",
    "ogl": "^1.0.11",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "wrangler": "^4.84.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
